
{
  "application": "T-Astro Web Studio",
  "version": "2025.1207-2-5END",
  "environment": {
    "recommended_node": ">=18.0.0",
    "required_permissions": ["geolocation"],
    "csp_policy": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;"
  },
  "layout_structure": {
    "desktop": {
      "header": "Header (Top)",
      "sidebar": "ControlPanel (Left, 384px)",
      "main": "MainView (Center/Right)",
      "footer": "StatusBar (Bottom, 40px/192px)"
    },
    "mobile": {
      "tabs": ["Planetarium", "Imaging View", "Equipment", "Control", "Settings"],
      "navigation": "Bottom Bar (64px)"
    }
  },
  "tabs": {
    "equipment": {
      "sections": [
        {
          "id": "backup",
          "title": "Backup & Restore",
          "functions": ["Save to Disk", "Load from Disk", "Google Drive Sync"]
        },
        {
          "id": "solver",
          "title": "Plate Solving Settings",
          "types": ["Remote (Astrometry.net)", "Local (API)"],
          "features": ["API Key Management", "Auto Center Toggle", "Profile Saving"]
        },
        {
          "id": "location",
          "title": "Location & Time",
          "inputs": ["Latitude", "Longitude", "Elevation", "Local Time"],
          "actions": ["GPS Update", "IP Update", "Sync to Mount", "Auto Sync", "Save Profile"]
        },
        {
          "id": "connection",
          "title": "Equipment Connection",
          "drivers": ["INDI", "Alpaca", "Simulator"],
          "logic": {
            "INDI": "WebSocket binary/text streaming with memory safety (64MB buffer limit)",
            "Alpaca": "REST API abstraction",
            "Simulator": "Internal mock state for testing"
          }
        }
      ]
    },
    "imaging": {
      "sections": [
        {
          "id": "stream",
          "title": "Live/Video Control",
          "actions": ["Start/Stop Loop (Polling)", "Start/Stop Live View (Native Native Stream)", "Encoder Selection"]
        },
        {
          "id": "camera_settings",
          "title": "Capture Parameters",
          "parameters": ["Exposure (ms)", "Gain", "Offset", "Binning", "Color Balance"]
        },
        {
          "id": "capture",
          "title": "Static Capture",
          "actions": ["Preview", "Live Stacking (10 frames)"],
          "formats": ["JPEG", "FITS", "TIFF"]
        },
        {
          "id": "focuser",
          "title": "Focuser Control",
          "actions": ["Step In", "Step Out", "Step Size Setting"],
          "integration": "Relative/Absolute INDI Focus protocol"
        }
      ]
    },
    "settings": {
      "sections": [
        {
          "id": "planetarium",
          "title": "Planetarium Settings",
          "toggles": ["Constellation Lines/Labels", "Grids", "Horizon", "Milky Way", "DSS Background"],
          "limits": ["Star Magnitude", "DSO Magnitude", "Star Scale", "Milky Way Opacity"]
        },
        {
          "id": "integrations",
          "title": "Third-party Integrations",
          "services": ["SAMP (Web Profile/XML-RPC)", "Gemini AI (Object Info API)", "Wikipedia/Simbad Data Fetching"]
        },
        {
          "id": "assets",
          "title": "System Asset",
          "functions": ["Save Application Manifest (Download app-definition.json)"]
        }
      ]
    }
  },
  "driver_logic": {
    "INDI_Binary_Handling": {
      "max_recv_buffer": "64MB",
      "max_blob_size": "128MB",
      "blob_tags": ["<oneBLOB", "</oneBLOB>"],
      "image_decoding": ["JPEG", "PNG", "FITS (Standard/Bayer)", "RAW8/RAW16"]
    },
    "Auto_Center_Routine": {
      "sequence": "Slew -> Wait -> Capture -> Plate Solve -> Sync -> Corrective Slew",
      "max_attempts": 5,
      "tolerance_deg": 0.05
    },
    "Dynamic_UI": {
      "polling_interval": "200ms for device properties",
      "coordinate_sync": "1000ms for telescope position feedback"
    }
  },
  "planetarium_initial_state": {
    "view": {
      "azimuth": 0,
      "altitude": 30,
      "zoom": 0.857
    },
    "defaults": {
      "star_mag_limit": 5.5,
      "dso_mag_limit": 10.0,
      "milky_way_opacity": 0.5,
      "star_scale": 1.0
    }
  }
}
